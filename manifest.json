{
  "manifest_version": 3,
  "name": "Chord Chart Getter",
  "version": "1.0.0",
  "description": "Find and download chord charts from your Spotify playlists",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "downloads",
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://open.spotify.com/*",
    "https://www.ultimate-guitar.com/*",
    "https://tabs.ultimate-guitar.com/*",
    "https://chordify.net/*",
    "https://www.songsterr.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Chord Chart Getter"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
