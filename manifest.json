{
  "manifest_version": 3,
  "name": "Playlists-to-Chord-Charts",
  "version": "1.0.0",
  "description": "Find chord charts from your music playlists on Spotify, Apple Music, YouTube Music, YouTube, and Tidal",
  "permissions": [
    "activeTab",
    "scripting",
    "sidePanel",
    "downloads",
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "https://open.spotify.com/*",
    "https://music.apple.com/*",
    "https://music.youtube.com/*",
    "https://www.youtube.com/*",
    "https://listen.tidal.com/*",
    "https://tidal.com/*",
    "https://www.ultimate-guitar.com/*",
    "https://tabs.ultimate-guitar.com/*",
    "https://chordify.net/*",
    "https://www.songsterr.com/*"
  ],
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "src/sidepanel/index.html"
  },
  "action": {
    "default_title": "Playlists-to-Chord-Charts",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  }
}
